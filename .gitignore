# ------------------------------------------------------------------------------
# OS / filesystem noise
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100/
.Trashes/
._*

Thumbs.db
Desktop.ini
ehthumbs.db
Icon?

*~
.*.swp
.*.swo
*.swp
*.swo
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej
*.retry

# ------------------------------------------------------------------------------
# Logs / runtime artifacts / reports
# ------------------------------------------------------------------------------
*.log
logs/
log/
*.out
*.err
*.trace
*.stackdump
*.pid
*.pid.lock
*.seed
*.gz
*.tgz

# ------------------------------------------------------------------------------
# Shell history / local shell artifacts
# ------------------------------------------------------------------------------
.zsh_history
.bash_history
.history
.histfile
.direnv/
.envrc
.envrc.local

# ------------------------------------------------------------------------------
# Environment files / local overrides / secrets
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

*.secret
*.secrets
*.token
*.tokens
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
*.jks
*.keystore
*.gpg
*.asc
*.age
*.sops.yaml
*.dec

secrets/
secret/
private/
vault/
vaults/
.pass/
passwords/
credentials/
creds/

# ------------------------------------------------------------------------------
# HashiCorp / secret tooling
# ------------------------------------------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

.vault-token
vault-token
*.vault
vault.hcl
!*.example.vault
!.vault.example

# ------------------------------------------------------------------------------
# Ansible / automation sensitive or generated files
# ------------------------------------------------------------------------------
*.retry
ansible.log
collections/
roles/*/files/secrets/
roles/*/templates/secrets/
group_vars/*vault*
host_vars/*vault*
*.vault.yml
*.vault.yaml
*.vault.json

